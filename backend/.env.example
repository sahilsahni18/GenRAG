# Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Model to use for generation
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated list of allowed frontend origins for CORS.
# Use "*" for local dev, and your real Vercel URL in production, e.g.
# FRONTEND_ORIGIN=https://genrag.vercel.app
FRONTEND_ORIGIN=*

# Device to run the sentence-transformers embedding model on
EMBEDDING_DEVICE=cpu

# Optional: override where the pre-computed embeddings CSV lives
# EMBEDDINGS_CSV_PATH=data/text_chunks_and_embeddings_df.csv
